# MCP Services Environment Configuration
# Copy this file to .env and fill in the required values

# Weather Service
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Time Service
# Use standard timezone names (e.g., Europe/Berlin, America/New_York)
# Leave empty to use system timezone
LOCAL_TIMEZONE=Europe/Berlin

# Logging
LOG_LEVEL=INFO

# Service Configuration
# Port for FastAPI servers (if running independently)
PORT=8000

# API Configuration
CORS_ORIGINS=*
