# Auto detect text files and normalize line endings to LF
* text=auto

# Python files
*.py text eol=lf
*.pyi text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Markdown
*.md text eol=lf
*.markdown text eol=lf

# YAML Configuration
*.yml text eol=lf
*.yaml text eol=lf

# JSON & related
*.json text eol=lf
*.jsonc text eol=lf

# Docker
Dockerfile text eol=lf
docker-compose.yml text eol=lf
.dockerignore text eol=lf

# Environment files
.env* text eol=lf
*.env* text eol=lf

# Text configuration files
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf

# Lock files
*.lock text eol=lf
pnpm-lock.yaml text eol=lf

# Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.git* binary
*.tar binary
*.tar.gz binary
*.zip binary
*.7z binary

# Documentation
LICENSE text eol=lf
README.md text eol=lf

# Template/Example files
*.example text eol=lf
*.template text eol=lf
*.sample text eol=lf
